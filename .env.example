# Vison-MCP Configuration
# Copy this file to .env and fill in your values for local development.
# For production (Claude Code): set these as environment variables.

VISIONAI_API_KEY=your-api-key-here
VISIONAI_BASE_URL=https://api.openai.com/v1
VISIONAI_MODEL_NAME=gpt-4o
# Video analysis mode: 'direct' (native API), 'frames' (FFmpeg sampling), 'auto' (detect)
VISIONAI_VIDEO_MODE=auto
